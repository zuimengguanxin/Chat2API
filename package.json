{
  "name": "chat2api",
  "version": "1.0.0",
  "description": "Chat2API - 统一管理多个 AI 服务提供商，提供 OpenAI 兼容 API 接口",
  "main": "./src/server/index.ts",
  "author": {
    "name": "Chat2API Team",
    "email": "support@chat2api.com"
  },
  "homepage": "https://github.com/chat2api/Chat2API-Manager",
  "license": "GPL-3.0",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:frontend\"",
    "dev:server": "npx tsx watch src/server/index.ts",
    "dev:frontend": "npx vite --config vite.config.ts",
    "build": "npx vite build --config vite.config.ts --outDir dist/web",
    "start": "npx tsx src/server/index.ts",
    "docker:build": "docker build -f Dockerfile.web -t chat2api .",
    "docker:run": "docker-compose up -d"
  },
  "dependencies": {
    "@koa/router": "^15.3.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "axios": "^1.7.7",
    "better-sqlite3": "^11.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "eventsource-parser": "^3.0.6",
    "i18next": "^25.8.11",
    "i18next-browser-languagedetector": "^8.2.1",
    "koa": "^2.15.3",
    "koa-bodyparser": "^4.4.1",
    "koa-static": "^5.0.0",
    "lucide-react": "^0.454.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.5.4",
    "react-router-dom": "^6.28.0",
    "react-window": "^2.2.7",
    "recharts": "^3.7.0",
    "tailwind-merge": "^2.5.4",
    "ws": "^8.18.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/koa": "^2.15.0",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/koa-static": "^4.0.4",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/react-window": "^1.8.8",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
